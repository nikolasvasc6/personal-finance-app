# Variaveis publicas do Supabase (prefixo EXPO_PUBLIC_ as expoe ao cliente).
# A anon key e publica por design no Supabase — RLS (Row Level Security) e
# quem protege os dados. NUNCA coloque service_role key aqui.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica
